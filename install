#!/bin/bash

set -e

### Set variables
DOTS="$(pwd)"

### Check distribution
source /etc/os-release

if [ "$NAME" = "Ubuntu" ]; then
    distro=ubuntu
    echo "Continuing"
else
    echo "No support has been added yet."
fi

### Install packages
if [ "$distro" = "ubuntu" ]; then
    echo "===> Increasing security"
    sudo ufw enable
    sudo ufw default deny incoming
    sudo ufw default allow outgoing
    echo "===> Setting up firewall rules"
    sudo ufw allow 1714:1764/tcp
    sudo ufw allow 1714:1764/udp
    sudo ufw allow 5353/udp
    echo "===> Installing font"
    cd /tmp
    wget https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/Iosevka.zip
    unzip Iosevka.zip
    mkdir -p ~/.local/share/fonts
    mv *.ttf ~/.local/share/fonts/ -v
    fc-cache -fv
    cd "$DOTS"
    echo "===> Installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    echo "===> Sourcing Homebrew"
    test -d /home/linuxbrew/.linuxbrew && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    echo "===> Installing apt packages"
    sudo dpkg --add-architecture i386
    wget https://cdn.akamai.steamstatic.com/client/installer/steam.deb
    sudo apt update
    sudo apt upgrade
    sudo apt update
    sudo apt install ca-certificates curl
    sudo install -m 0755 -d /etc/apt/keyrings
    sudo curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
    sudo chmod a+r /etc/apt/keyrings/docker.asc
    sudo tee /etc/apt/sources.list.d/docker.sources <<EOF
Types: deb
URIs: https://download.docker.com/linux/ubuntu
Suites: $(. /etc/os-release && echo "${UBUNTU_CODENAME:-$VERSION_CODENAME}")
Components: stable
Architectures: $(dpkg --print-architecture)
Signed-By: /etc/apt/keyrings/docker.asc
EOF
    sudo apt update
    sudo apt install ./steam.deb
    sudo apt --fix-missing install
    sudo apt update
    sudo apt install -y fzf ripgrep emacs flatpak stow gnome-software-plugin-flatpak gnome-software gnome-shell-extensions ssh gnome-tweaks alacritty pipx
    rm steam.deb
    sudo apt update && sudo apt install extrepo -y
    sudo extrepo enable librewolf && sudo extrepo update librewolf
    sudo apt update && sudo apt install librewolf -y
    echo "===> Installing dotfiles"
    mkdir -p ~/.emacs.d
    mv ~/.bashrc ~/.bashrc.bak
    stow */
    dconf load /org/gnome/shell/extensions/ < extensions.txt
    dconf load /org/gnome/desktop/ < desktop.txt
    echo "===> Setting up Flatpak"
    flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
    echo "===> Installing Homebrew packages"
    brew bundle
    echo "===> Installing Snaps"
    sudo snap install obsidian --classic
    sudo snap install spotify
    sudo snap install mission-center
    echo "===> Installing GNOME extensions"
    if ! command -v ~/.local/bin/gext &> /dev/null; then
	pipx install gnome-extensions-cli --system-site-packages
    fi

    EXTENSIONS=(
	"tactile@lundal.io"
	"space-bar@luchrioh"
	"switcher@landau.fi"
	"clipboard-indicator@tudmotu.com"
	"emoji-copy@felipeftn"
	"gsconnect@andyholmes.github.io"
	"compiz-windows-effect@hermes83.github.com"
	"just-perfection-desktop@just-perfection"
    )

    for ext in "${EXTENSIONS[@]}"; do
	if ! ~/.local/bin/gext list | grep "$ext" &> /dev/null; then
	    echo "==> Installing extension: $ext"
	    ~/.local/bin/gext install "$ext"
	else
	    echo "==> Extension already installed: $ext"
	fi
    done
    echo "===> Setting alacritty as terminal"
    sudo update-alternatives --config x-terminal-emulator
    echo "===> Caveats"
    echo "==> You need to manually disable the Ubuntu Dock."
    echo "==> You should manually change the Docker root directory."
    echo "==> You should manually set up git email and username, set up gpg and ssh keys, and set up git to sign commits with gpg."
    echo "==> You should manually set Librewolf as default browser and configure Librewolf."
    echo "==> You should manually set swappiness to 10 and set up ZRAM."
fi
