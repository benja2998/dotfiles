#!/bin/sh

set -x

printf "Have you set up GPG keys and set up git to always sign with GPG? (answer yes or no): "

read -r answer

if [ "$answer" = "yes" ]; then
    no=op
elif [ "$answer" = "no" ]; then
    exit 1
else
    exit 1
fi

mkdir -p ~/.config
mkdir -p ~/.emacs.d
mkdir -p ~/.gnupg

dotfiles=$(pwd)

cd ..
parent=$(pwd)

cd "$dotfiles"

if [ "$parent" = "$HOME" ]; then
    no=op
else
    exit 1
fi

pkg_cmd="sudo apt-get install -y" # Default

if [ -n "$TERMUX_VERSION" ]; then
    upg_cmd="pkg up -y"
    pkg_cmd="pkg i -y"
    pkgs="emacs termux-services build-essential stow ripgrep fzf"
elif [ "$(uname)" = "Darwin" ]; then
    upg_cmd="brew update"
    upg2_cmd="brew upgrade"
    upg3_cmd="brew cleanup"
    pkg_cmd="brew install"
    pkgs="ripgrep stow fzf git gcc"
    casks="emacs-app firefox"
elif [ "$(uname)" = "Linux" ]; then
    . /etc/os-release
    if [ "$ID_LIKE" = "debian" ] || [ "$ID" = "debian" ]; then
        upg_cmd="sudo apt-get upgrade -y"
	    pkg_cmd="sudo apt-get install -y"
	    pkgs="build-essential emacs fzf stow ripgrep"
    else
	    exit 1
    fi
else
    exit 1
fi

# Set up brew
if [ "$(uname)" = "Darwin" ]; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

$upg_cmd
$upg2_cmd
$upg3_cmd
$pkg_cmd $pkgs

# Install casks if on macOS
if [ "$(uname)" = "Darwin" ]; then
    $pkg_cmd --cask $casks
fi

if [ -x "$(command -v stow)" ]; then
    no=op
else
    exit 1
fi

printf "Do you want to install every package, or only some? (answer every or some): "

read -r answer

if [ "$answer" = "every" ]; then
    rm ~/.emacs.d/init.el
    rm ~/.emacs.d/custom.el
    rm ~/.bashrc
    rm ~/.zshrc
    rm ~/.nanorc
    rm ~/.gnupg/gpg-agent.conf
    rm ~/.gnupg/gpg.conf
    rm ~/.emacs.d/local -r
    rm ~/.config/fastfetch -r
    stow */
elif [ "$answer" = "some" ]; then
    printf "Package to install?: "
    read -r package
    if [ "$package" = "" ]; then
	    exit 1
    fi
    stow "$package"
else
    exit 1
fi

set -e

printf "Git email: "
read -r email
printf "Git username: "
read -r name
git config --global user.email "$email"
git config --global user.name "$name"
git config --global core.editor nano
git config --global init.defaultBranch main

set +e
